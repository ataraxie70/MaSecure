# =============================================================================
# MaSecure — Variables d'environnement (copier en .env et adapter)
# ATTENTION : Ne jamais commiter le fichier .env dans le dépôt git.
# =============================================================================

# Base de données
DATABASE_URL=postgresql://masecure:masecure_dev_password@localhost:5432/masecure_dev?sslmode=disable

# NATS JetStream
NATS_URL=nats://localhost:4222

# Kernel Financier
KERNEL_SERVICE_NAME=kernel-financial@1.0.0
KERNEL_HTTP_ADDR=0.0.0.0:8001
KERNEL_INTERNAL_URL=http://127.0.0.1:8001
PAYOUT_SCHEDULER_INTERVAL_SECONDS=60

# Gateway WhatsApp Business API
WHATSAPP_APP_SECRET=your_meta_app_secret_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# Intégration Mobile Money (agrégateur — ex: CinetPay, Bizao, PayExpresse)
# `live` utilise un POST /payouts signé avec X-API-Key et X-Signature.
MOBILE_MONEY_MODE=mock  # mock | live
MOBILE_MONEY_AGGREGATOR_URL=https://api.aggregator.example.com
MOBILE_MONEY_API_KEY=your_api_key_here
MOBILE_MONEY_HMAC_SECRET=your_hmac_secret_here
MOBILE_MONEY_CALLBACK_BASE_URL=http://127.0.0.1:8000
MOBILE_MONEY_SIMULATOR_LISTEN_ADDR=0.0.0.0:18002
MOBILE_MONEY_SIMULATOR_MODE=success  # success | failed
MOBILE_MONEY_SIMULATOR_DELAY_MS=250

# Sécurité
CALLBACK_HMAC_SECRET=your_callback_hmac_secret_here  # utilisé pour tous les callbacks entrants opérateur

# Logging
LOG_LEVEL=info  # debug | info | warn | error

# Environment
ENV=development  # development | staging | production

# ── Phase 3 : Service Social ──────────────────────────────────────────────────
SOCIAL_HTTP_ADDR=0.0.0.0:8002
SOCIAL_SERVICE_NAME=social-service@1.0.0

# ── Phase 4 : Résilience ──────────────────────────────────────────────────────
# Politique par défaut pour les cycles dont le seuil n'est pas atteint
# Valeurs : wait_for_threshold | use_working_capital | pro_rata | working_capital_then_pro_rata
DEFAULT_RESILIENCE_POLICY=wait_for_threshold

# ── Phase 5 : Notifications WhatsApp réelles ──────────────────────────────────
WHATSAPP_API_VERSION=v19.0
# WHATSAPP_PHONE_NUMBER_ID déjà défini ci-dessus
# WHATSAPP_ACCESS_TOKEN déjà défini ci-dessus
SMS_FALLBACK_ENABLED=true
SMS_GATEWAY_URL=https://api.your-sms-provider.com
SMS_API_KEY=your_sms_api_key_here
SMS_SENDER_ID=MaSecure

# ── Phase 5 : Compliance BCEAO ────────────────────────────────────────────────
# Alertes AML — seuil en centimes XOF (100 000 000 = 1 000 000 XOF)
AML_THRESHOLD_MINOR=100000000
# Rétention légale en années (BCEAO : 10 ans minimum)
BCEAO_RETENTION_YEARS=10

# ── Phase 5 : Mobile Money Callback URL (pour providers réels) ────────────────
# URL publique accessible par l'agrégateur pour envoyer les callbacks
# ex: https://api.masecure.bf (doit être HTTPS en production)
# MOBILE_MONEY_CALLBACK_BASE_URL déjà défini ci-dessus
